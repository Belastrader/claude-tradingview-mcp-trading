// ═══════════════════════════════════════════════════════════════
//  BTC Momentum Bot v4 — Indicador Visual
//  Replica exatamente a lógica do bot:
//    EMA 8/21 (3m) + Tendência 15m + RSI 50-65/35-50 + Volume 1.3x
//  Mostra: entradas, TP e SL no gráfico
// ═══════════════════════════════════════════════════════════════
//@version=5
indicator("BTC Momentum Bot v4", overlay=true, max_labels_count=500, max_lines_count=500)

// ──────────────────────────────────────────────────────────────
//  CONFIGURAÇÕES (ajuste para testar diferentes parâmetros)
// ──────────────────────────────────────────────────────────────
tp_pct   = input.float(0.8, "Take Profit (%)", minval=0.1, step=0.1, group="Saída") / 100
sl_pct   = input.float(0.4, "Stop Loss (%)",   minval=0.1, step=0.1, group="Saída") / 100
vol_mult = input.float(1.3, "Volume mínimo (x média 20c)", minval=1.0, step=0.1, group="Filtros")
rsi_long_min  = input.int(50, "RSI Long — mín",  minval=30, maxval=70, group="Filtros")
rsi_long_max  = input.int(65, "RSI Long — máx",  minval=30, maxval=80, group="Filtros")
rsi_short_min = input.int(35, "RSI Short — mín", minval=20, maxval=50, group="Filtros")
rsi_short_max = input.int(50, "RSI Short — máx", minval=30, maxval=70, group="Filtros")
show_emas     = input.bool(true, "Mostrar EMAs", group="Visual")
show_vwap     = input.bool(true, "Mostrar VWAP", group="Visual")
show_bg       = input.bool(true, "Fundo colorido (tendência 15m)", group="Visual")
line_bars     = input.int(40, "Comprimento das linhas TP/SL (candles)", minval=5, maxval=200, group="Visual")

// ──────────────────────────────────────────────────────────────
//  INDICADORES — TIMEFRAME ATUAL (3m)
// ──────────────────────────────────────────────────────────────
ema8  = ta.ema(close, 8)
ema21 = ta.ema(close, 21)
rsi14 = ta.rsi(close, 14)
[vwap_val, _, _] = ta.vwap(hlc3)
vol_avg = ta.sma(volume, 20)

// ──────────────────────────────────────────────────────────────
//  TENDÊNCIA 15M (filtro principal da v4)
// ──────────────────────────────────────────────────────────────
ema8_15m  = request.security(syminfo.tickerid, "15", ta.ema(close, 8),  lookahead=barmerge.lookahead_off)
ema21_15m = request.security(syminfo.tickerid, "15", ta.ema(close, 21), lookahead=barmerge.lookahead_off)
trend_bull = ema8_15m > ema21_15m
trend_bear = ema8_15m < ema21_15m

// ──────────────────────────────────────────────────────────────
//  CONDIÇÕES — IDÊNTICAS AO BOT
// ──────────────────────────────────────────────────────────────
bull_bias = close > vwap_val
bear_bias = close < vwap_val
vol_ok    = volume >= vol_avg * vol_mult

rsi_long_ok  = rsi14 >= rsi_long_min  and rsi14 <= rsi_long_max
rsi_short_ok = rsi14 >= rsi_short_min and rsi14 <= rsi_short_max

long_cond  = bull_bias and ema8 > ema21 and trend_bull and rsi_long_ok  and vol_ok
short_cond = bear_bias and ema8 < ema21 and trend_bear and rsi_short_ok and vol_ok

// Dispara só no primeiro candle que satisfaz (evita setas consecutivas)
long_entry  = long_cond  and not long_cond[1]
short_entry = short_cond and not short_cond[1]

// ──────────────────────────────────────────────────────────────
//  PLOTS BASE
// ──────────────────────────────────────────────────────────────
plot(show_emas ? ema8  : na, "EMA 8",  color=color.new(color.blue,   0), linewidth=2)
plot(show_emas ? ema21 : na, "EMA 21", color=color.new(color.orange, 0), linewidth=2)
plot(show_vwap ? vwap_val : na, "VWAP", color=color.new(color.purple, 20), linewidth=2, style=plot.style_circles)

// Fundo: verde = 15m em alta, vermelho = 15m em baixa
bgcolor(show_bg and trend_bull ? color.new(color.green, 93) :
        show_bg and trend_bear ? color.new(color.red,   93) : na, title="Tendência 15m")

// ──────────────────────────────────────────────────────────────
//  ENTRADAS LONGAS — seta + TP + SL
// ──────────────────────────────────────────────────────────────
if long_entry
    entry = close
    tp    = entry * (1 + tp_pct)
    sl    = entry * (1 - sl_pct)

    // Seta de entrada
    label.new(bar_index, low,
              "▲ LONG\n$" + str.tostring(entry, "#.00"),
              yloc      = yloc.belowbar,
              color     = color.new(color.green, 0),
              textcolor = color.white,
              style     = label.style_label_up,
              size      = size.small)

    // Linha TP
    line.new(bar_index, tp, bar_index + line_bars, tp,
             color = color.new(color.green, 0), width = 2, style = line.style_dashed)
    label.new(bar_index + line_bars, tp,
              "TP +" + str.tostring(tp_pct * 100, "#.#") + "%  $" + str.tostring(tp, "#.00"),
              color     = color.new(color.green, 10),
              textcolor = color.white,
              style     = label.style_label_left,
              size      = size.tiny)

    // Linha SL
    line.new(bar_index, sl, bar_index + line_bars, sl,
             color = color.new(color.red, 0), width = 2, style = line.style_dashed)
    label.new(bar_index + line_bars, sl,
              "SL -" + str.tostring(sl_pct * 100, "#.#") + "%  $" + str.tostring(sl, "#.00"),
              color     = color.new(color.red, 10),
              textcolor = color.white,
              style     = label.style_label_left,
              size      = size.tiny)

// ──────────────────────────────────────────────────────────────
//  ENTRADAS CURTAS — seta + TP + SL
// ──────────────────────────────────────────────────────────────
if short_entry
    entry = close
    tp    = entry * (1 - tp_pct)
    sl    = entry * (1 + sl_pct)

    label.new(bar_index, high,
              "▼ SHORT\n$" + str.tostring(entry, "#.00"),
              yloc      = yloc.abovebar,
              color     = color.new(color.red, 0),
              textcolor = color.white,
              style     = label.style_label_down,
              size      = size.small)

    line.new(bar_index, tp, bar_index + line_bars, tp,
             color = color.new(color.green, 0), width = 2, style = line.style_dashed)
    label.new(bar_index + line_bars, tp,
              "TP +" + str.tostring(tp_pct * 100, "#.#") + "%  $" + str.tostring(tp, "#.00"),
              color     = color.new(color.green, 10),
              textcolor = color.white,
              style     = label.style_label_left,
              size      = size.tiny)

    line.new(bar_index, sl, bar_index + line_bars, sl,
             color = color.new(color.red, 0), width = 2, style = line.style_dashed)
    label.new(bar_index + line_bars, sl,
              "SL -" + str.tostring(sl_pct * 100, "#.#") + "%  $" + str.tostring(sl, "#.00"),
              color     = color.new(color.red, 10),
              textcolor = color.white,
              style     = label.style_label_left,
              size      = size.tiny)

// ──────────────────────────────────────────────────────────────
//  PAINEL DE STATUS — canto superior direito
// ──────────────────────────────────────────────────────────────
var table painel = table.new(position.top_right, 2, 7,
     bgcolor      = color.new(color.black, 60),
     border_color = color.new(color.gray, 50),
     border_width = 1,
     frame_color  = color.new(color.gray, 30),
     frame_width  = 1)

if barstate.islast
    ema3m_status  = ema8 > ema21 ? "▲ ALTA"   : "▼ BAIXA"
    ema3m_cor     = ema8 > ema21 ? color.green  : color.red
    ema15m_status = trend_bull   ? "▲ ALTA"   : "▼ BAIXA"
    ema15m_cor    = trend_bull   ? color.green  : color.red
    vwap_status   = close > vwap_val ? "▲ acima" : "▼ abaixo"
    vwap_cor      = close > vwap_val ? color.green : color.red
    rsi_zone      = rsi_long_ok  ? "✓ zona LONG"  :
                    rsi_short_ok ? "✓ zona SHORT" :
                    rsi14 < rsi_short_min ? "⬇ oversold" :
                    rsi14 > rsi_long_max  ? "⬆ overbought" : "— neutro"
    rsi_cor       = (rsi_long_ok or rsi_short_ok) ? color.green : color.orange
    vol_status    = vol_ok ? "✓ forte" : "✗ fraco"
    vol_cor       = vol_ok ? color.green : color.red

    sinal = long_cond ? "✅  LONG" : short_cond ? "✅  SHORT" : "⏸  AGUARDANDO"
    sinal_cor = long_cond ? color.green : short_cond ? color.red : color.gray

    // Cabeçalho
    table.cell(painel, 0, 0, "BOT v4",    text_color=color.white, bgcolor=color.new(color.navy, 20),  text_size=size.small, text_halign=text.align_center)
    table.cell(painel, 1, 0, "BTCUSDT 3m", text_color=color.white, bgcolor=color.new(color.navy, 20), text_size=size.small, text_halign=text.align_center)

    table.cell(painel, 0, 1, "EMA 3m",    text_color=color.gray,  text_size=size.tiny)
    table.cell(painel, 1, 1, ema3m_status,  text_color=ema3m_cor,   text_size=size.tiny)

    table.cell(painel, 0, 2, "Tend. 15m", text_color=color.gray,  text_size=size.tiny)
    table.cell(painel, 1, 2, ema15m_status, text_color=ema15m_cor,  text_size=size.tiny)

    table.cell(painel, 0, 3, "VWAP",      text_color=color.gray,  text_size=size.tiny)
    table.cell(painel, 1, 3, vwap_status,   text_color=vwap_cor,    text_size=size.tiny)

    table.cell(painel, 0, 4, "RSI " + str.tostring(rsi14, "#.#"), text_color=color.gray, text_size=size.tiny)
    table.cell(painel, 1, 4, rsi_zone,       text_color=rsi_cor,    text_size=size.tiny)

    table.cell(painel, 0, 5, "Volume",    text_color=color.gray,  text_size=size.tiny)
    table.cell(painel, 1, 5, vol_status,    text_color=vol_cor,    text_size=size.tiny)

    table.cell(painel, 0, 6, "Sinal",     text_color=color.gray,  text_size=size.small)
    table.cell(painel, 1, 6, sinal,         text_color=sinal_cor,  text_size=size.small, text_halign=text.align_center)

// ──────────────────────────────────────────────────────────────
//  ALERTAS (funciona no plano pago para automação futura)
// ──────────────────────────────────────────────────────────────
alertcondition(long_entry,  "BOT — LONG",  '{"action":"long","symbol":"BTCUSDT","price":"{{close}}"}')
alertcondition(short_entry, "BOT — SHORT", '{"action":"short","symbol":"BTCUSDT","price":"{{close}}"}')
